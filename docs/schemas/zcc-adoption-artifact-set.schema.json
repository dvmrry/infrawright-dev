{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://infrawright.local/schemas/zcc-adoption-artifact-set.schema.json",
  "title": "Infrawright Provider-Observed ZCC Bootstrap Adoption Artifact Set",
  "$comment": "A successful value is a read-only bootstrap candidate compiled from the exact bound pull and provider-observed state. It does not claim Python parity, plan cleanliness, apply readiness, live qualification, or cutover readiness.",
  "type": "object",
  "x-infrawright-zcc-pull-artifact-semantics": true,
  "additionalProperties": false,
  "required": [
    "kind",
    "schema_version",
    "mode",
    "product",
    "resource_type",
    "tenant",
    "source",
    "catalog",
    "root",
    "artifacts"
  ],
  "properties": {
    "kind": {
      "const": "infrawright.zcc_adoption_artifact_set"
    },
    "schema_version": {
      "const": 1
    },
    "mode": {
      "const": "bootstrap"
    },
    "product": {
      "const": "zcc"
    },
    "resource_type": {
      "$ref": "zcc-pull-artifact-set.schema.json#/$defs/resourceType"
    },
    "tenant": {
      "type": "string",
      "pattern": "^(?!\\.{1,2}$)[A-Za-z0-9_.-]+$"
    },
    "source": {
      "$ref": "zcc-pull-artifact-set.schema.json#/$defs/source"
    },
    "catalog": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "schema_version",
        "sha256",
        "sources_sha256"
      ],
      "properties": {
        "kind": {
          "const": "infrawright.adoption_catalog"
        },
        "schema_version": {
          "const": 1
        },
        "sha256": {
          "const": "ba1690397bbe84e6284affee2cfe8300f0ebb230714c332d6ff93d04a42181e7"
        },
        "sources_sha256": {
          "const": "90452e9199dcc4dbf578e9f3af21ae2fb35517eb5d3af0f1a193f2e5ed92ed11"
        }
      }
    },
    "root": {
      "$ref": "zcc-pull-artifact-set.schema.json#/$defs/root"
    },
    "artifacts": {
      "$ref": "zcc-pull-artifact-set.schema.json#/$defs/artifacts"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "resource_type": {
            "const": "zcc_trusted_network"
          }
        }
      },
      "then": {
        "properties": {
          "artifacts": {
            "type": "object",
            "properties": {
              "lookup": {
                "$ref": "zcc-pull-artifact-set.schema.json#/$defs/jsonArtifact"
              }
            }
          }
        }
      },
      "else": {
        "properties": {
          "artifacts": {
            "type": "object",
            "properties": {
              "lookup": {
                "type": "null"
              }
            }
          }
        }
      }
    }
  ]
}
