{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://infrawright.local/schemas/root-catalog.schema.json",
  "title": "Infrawright Root Catalog",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "kind",
    "schema_version",
    "declared_providers",
    "resources",
    "source_files",
    "sources_sha256"
  ],
  "properties": {
    "kind": {
      "const": "infrawright.root_catalog"
    },
    "schema_version": {
      "const": 1
    },
    "declared_providers": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "resources": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/resource"
      }
    },
    "source_files": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "sources_sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    }
  },
  "$defs": {
    "resource": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "product",
        "provider",
        "bare_name",
        "slug_label",
        "generated",
        "derived"
      ],
      "properties": {
        "type": {
          "type": "string",
          "minLength": 1
        },
        "product": {
          "type": "string",
          "minLength": 1
        },
        "provider": {
          "type": "string",
          "minLength": 1
        },
        "bare_name": {
          "type": "string",
          "minLength": 1
        },
        "slug_label": {
          "type": [
            "string",
            "null"
          ]
        },
        "generated": {
          "type": "boolean"
        },
        "derived": {
          "type": "boolean"
        }
      }
    }
  }
}
