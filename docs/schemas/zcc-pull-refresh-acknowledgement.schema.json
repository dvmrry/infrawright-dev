{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://infrawright.local/schemas/zcc-pull-refresh-acknowledgement.schema.json",
  "title": "Infrawright ZCC Pull Refresh Acknowledgement",
  "$comment": "x-infrawright-zcc-pull-refresh-acknowledgement-semantics is required. The result records exact retirement after a trusted external apply acknowledgement; it explicitly does not claim that the engine observed Terraform apply.",
  "type": "object",
  "x-infrawright-zcc-pull-refresh-acknowledgement-semantics": true,
  "additionalProperties": false,
  "required": [
    "kind",
    "schema_version",
    "mode",
    "product",
    "resource_type",
    "tenant",
    "status",
    "evidence",
    "retirement",
    "verification"
  ],
  "properties": {
    "kind": {
      "const": "infrawright.zcc_pull_refresh_acknowledgement"
    },
    "schema_version": {
      "const": 1
    },
    "mode": {
      "const": "refresh"
    },
    "product": {
      "const": "zcc"
    },
    "resource_type": {
      "$ref": "zcc-pull-artifact-set.schema.json#/$defs/resourceType"
    },
    "tenant": {
      "type": "string",
      "pattern": "^(?!\\.{1,2}$)[A-Za-z0-9_.-]+$"
    },
    "status": {
      "const": "retired"
    },
    "evidence": {
      "$ref": "#/$defs/evidence"
    },
    "retirement": {
      "$ref": "#/$defs/retirement"
    },
    "verification": {
      "$ref": "#/$defs/verification"
    }
  },
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "absent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["state"],
      "properties": {
        "state": {
          "const": "absent"
        }
      }
    },
    "present": {
      "type": "object",
      "additionalProperties": false,
      "required": ["state", "sha256", "size_bytes"],
      "properties": {
        "state": {
          "const": "present"
        },
        "sha256": {
          "$ref": "#/$defs/sha256"
        },
        "size_bytes": {
          "type": "integer",
          "minimum": 0,
          "maximum": 33554432
        }
      }
    },
    "contentState": {
      "oneOf": [
        {
          "$ref": "#/$defs/absent"
        },
        {
          "$ref": "#/$defs/present"
        }
      ]
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "statement", "apply_observed_by_engine"],
      "properties": {
        "kind": {
          "const": "trusted_pipeline_assertion"
        },
        "statement": {
          "const": "terraform_apply_succeeded"
        },
        "apply_observed_by_engine": {
          "const": false
        }
      }
    },
    "retirement": {
      "type": "object",
      "additionalProperties": false,
      "required": ["policy", "initial", "removed", "final", "next_action"],
      "properties": {
        "policy": {
          "const": "retire_exact_after_external_acknowledgement"
        },
        "initial": {
          "enum": ["awaiting_apply", "retirement_prefix", "already_retired"]
        },
        "removed": {
          "type": "array",
          "maxItems": 2,
          "uniqueItems": true,
          "items": {
            "enum": ["moves", "pending_moves"]
          }
        },
        "final": {
          "const": "retired"
        },
        "next_action": {
          "const": "none"
        }
      }
    },
    "artifactStates": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "tfvars",
        "imports",
        "lookup",
        "moves",
        "pending_moves",
        "alternate_hcl",
        "generated_bindings"
      ],
      "properties": {
        "tfvars": {
          "$ref": "#/$defs/present"
        },
        "imports": {
          "$ref": "#/$defs/present"
        },
        "lookup": {
          "$ref": "#/$defs/contentState"
        },
        "moves": {
          "$ref": "#/$defs/absent"
        },
        "pending_moves": {
          "$ref": "#/$defs/absent"
        },
        "alternate_hcl": {
          "$ref": "#/$defs/absent"
        },
        "generated_bindings": {
          "$ref": "#/$defs/absent"
        }
      }
    },
    "verification": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "candidate_request_sha256",
        "assertion_sha256",
        "publication_receipt_sha256",
        "baseline_fingerprint_sha256",
        "transition_sha256",
        "artifacts"
      ],
      "properties": {
        "candidate_request_sha256": {
          "$ref": "#/$defs/sha256"
        },
        "assertion_sha256": {
          "$ref": "#/$defs/sha256"
        },
        "publication_receipt_sha256": {
          "$ref": "#/$defs/sha256"
        },
        "baseline_fingerprint_sha256": {
          "$ref": "#/$defs/sha256"
        },
        "transition_sha256": {
          "$ref": "#/$defs/sha256"
        },
        "artifacts": {
          "$ref": "#/$defs/artifactStates"
        }
      }
    }
  }
}
