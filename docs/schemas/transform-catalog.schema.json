{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://infrawright.local/schemas/transform-catalog.schema.json",
  "title": "Infrawright ZCC Transform Catalog",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "kind",
    "schema_version",
    "product",
    "resources",
    "python_compatibility",
    "source_files",
    "sources_sha256"
  ],
  "properties": {
    "kind": {
      "const": "infrawright.transform_catalog"
    },
    "schema_version": {
      "const": 1
    },
    "product": {
      "const": "zcc"
    },
    "resources": {
      "type": "array",
      "minItems": 5,
      "maxItems": 5,
      "items": {
        "$ref": "#/$defs/resource"
      },
      "allOf": [
        {
          "contains": {
            "type": "object",
            "properties": {
              "type": {
                "const": "zcc_device_cleanup"
              }
            },
            "required": [
              "type"
            ]
          }
        },
        {
          "contains": {
            "type": "object",
            "properties": {
              "type": {
                "const": "zcc_failopen_policy"
              }
            },
            "required": [
              "type"
            ]
          }
        },
        {
          "contains": {
            "type": "object",
            "properties": {
              "type": {
                "const": "zcc_forwarding_profile"
              }
            },
            "required": [
              "type"
            ]
          }
        },
        {
          "contains": {
            "type": "object",
            "properties": {
              "type": {
                "const": "zcc_trusted_network"
              }
            },
            "required": [
              "type"
            ]
          }
        },
        {
          "contains": {
            "type": "object",
            "properties": {
              "type": {
                "const": "zcc_web_privacy"
              }
            },
            "required": [
              "type"
            ]
          }
        }
      ]
    },
    "python_compatibility": {
      "$ref": "#/$defs/pythonCompatibility"
    },
    "source_files": {
      "type": "array",
      "minItems": 8,
      "maxItems": 8,
      "uniqueItems": true,
      "items": {
        "enum": [
          "zcc/overrides/zcc_device_cleanup.json",
          "zcc/overrides/zcc_failopen_policy.json",
          "zcc/overrides/zcc_forwarding_profile.json",
          "zcc/overrides/zcc_trusted_network.json",
          "zcc/overrides/zcc_web_privacy.json",
          "zcc/pack.json",
          "zcc/registry.json",
          "zcc/schemas/provider/zcc.json"
        ]
      }
    },
    "sources_sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    }
  },
  "$defs": {
    "fieldName": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*$"
    },
    "fieldPath": {
      "type": "string",
      "minLength": 1
    },
    "primitiveEncoding": {
      "enum": [
        "bool",
        "number",
        "string"
      ]
    },
    "encoding": {
      "oneOf": [
        {
          "$ref": "#/$defs/primitiveEncoding"
        },
        {
          "type": "array",
          "minItems": 2,
          "maxItems": 2,
          "prefixItems": [
            {
              "const": "list"
            },
            {
              "$ref": "#/$defs/primitiveEncoding"
            }
          ],
          "items": false
        }
      ]
    },
    "projection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "attributes",
        "blocks",
        "silently_ignored_attributes"
      ],
      "properties": {
        "attributes": {
          "type": "object",
          "propertyNames": {
            "$ref": "#/$defs/fieldName"
          },
          "additionalProperties": {
            "$ref": "#/$defs/encoding"
          }
        },
        "blocks": {
          "type": "object",
          "propertyNames": {
            "$ref": "#/$defs/fieldName"
          },
          "additionalProperties": {
            "$ref": "#/$defs/blockProjection"
          }
        },
        "silently_ignored_attributes": {
          "type": "array",
          "maxItems": 1,
          "uniqueItems": true,
          "items": {
            "const": "id"
          }
        }
      }
    },
    "blockProjection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "cardinality",
        "projection"
      ],
      "properties": {
        "cardinality": {
          "enum": [
            "single",
            "many"
          ]
        },
        "projection": {
          "$ref": "#/$defs/projection"
        }
      }
    },
    "resource": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "key_fields",
        "html_unescape_passes",
        "acknowledged_drops",
        "invert_bool",
        "import_id",
        "lookup_source",
        "renames",
        "references",
        "split_csv",
        "projection"
      ],
      "properties": {
        "type": {
          "enum": [
            "zcc_device_cleanup",
            "zcc_failopen_policy",
            "zcc_forwarding_profile",
            "zcc_trusted_network",
            "zcc_web_privacy"
          ]
        },
        "key_fields": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/fieldName"
          }
        },
        "html_unescape_passes": {
          "enum": [
            0,
            2
          ]
        },
        "acknowledged_drops": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/fieldPath"
          }
        },
        "invert_bool": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/fieldName"
          }
        },
        "import_id": {
          "$ref": "#/$defs/importId"
        },
        "lookup_source": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "$ref": "#/$defs/lookupSource"
            }
          ]
        },
        "renames": {
          "type": "object",
          "propertyNames": {
            "$ref": "#/$defs/fieldName"
          },
          "additionalProperties": {
            "$ref": "#/$defs/fieldName"
          }
        },
        "references": {
          "type": "object",
          "propertyNames": {
            "$ref": "#/$defs/fieldName"
          },
          "additionalProperties": {
            "$ref": "#/$defs/reference"
          }
        },
        "split_csv": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/fieldName"
          }
        },
        "projection": {
          "$ref": "#/$defs/projection"
        }
      }
    },
    "importId": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "template",
        "segments"
      ],
      "properties": {
        "template": {
          "type": "string",
          "minLength": 1
        },
        "segments": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/importIdSegment"
          }
        }
      }
    },
    "importIdSegment": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "literal"
          ],
          "properties": {
            "literal": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "field"
          ],
          "properties": {
            "field": {
              "$ref": "#/$defs/fieldName"
            }
          }
        }
      ]
    },
    "lookupSource": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name_field"
      ],
      "properties": {
        "name_field": {
          "$ref": "#/$defs/fieldName"
        }
      }
    },
    "reference": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "referent",
        "name_field"
      ],
      "properties": {
        "referent": {
          "enum": [
            "zcc_device_cleanup",
            "zcc_failopen_policy",
            "zcc_forwarding_profile",
            "zcc_trusted_network",
            "zcc_web_privacy"
          ]
        },
        "name_field": {
          "$ref": "#/$defs/fieldName"
        }
      }
    },
    "pythonCompatibility": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "html_unescape"
      ],
      "properties": {
        "html_unescape": {
          "$ref": "#/$defs/htmlUnescapeCompatibility"
        }
      }
    },
    "htmlUnescapeCompatibility": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "entities",
        "invalid_codepoints",
        "invalid_references"
      ],
      "properties": {
        "entities": {
          "type": "object",
          "minProperties": 1,
          "propertyNames": {
            "type": "string",
            "minLength": 1
          },
          "additionalProperties": {
            "type": "string"
          }
        },
        "invalid_codepoints": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "integer",
            "minimum": 0,
            "maximum": 1114111
          }
        },
        "invalid_references": {
          "type": "object",
          "propertyNames": {
            "pattern": "^(0|[1-9][0-9]*)$"
          },
          "additionalProperties": {
            "type": "string"
          }
        }
      }
    }
  }
}
