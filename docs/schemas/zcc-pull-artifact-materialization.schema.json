{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://infrawright.local/schemas/zcc-pull-artifact-materialization.schema.json",
  "title": "Infrawright ZCC Bootstrap Pull Artifact Materialization",
  "$comment": "x-infrawright-zcc-pull-materialization-semantics is a required Infrawright vocabulary assertion. Structural JSON Schema validation alone is insufficient: implementations must also bind tenant/resource verification evidence, enforce a sorted disjoint complete created/reused partition, and require exact final artifact matches.",
  "type": "object",
  "x-infrawright-zcc-pull-materialization-semantics": true,
  "additionalProperties": false,
  "required": [
    "kind",
    "schema_version",
    "mode",
    "product",
    "resource_type",
    "tenant",
    "status",
    "publication",
    "verification"
  ],
  "properties": {
    "kind": {
      "const": "infrawright.zcc_pull_artifact_materialization"
    },
    "schema_version": {
      "const": 1
    },
    "mode": {
      "const": "bootstrap"
    },
    "product": {
      "const": "zcc"
    },
    "resource_type": {
      "$ref": "zcc-pull-artifact-parity.schema.json#/$defs/resourceType"
    },
    "tenant": {
      "type": "string",
      "pattern": "^(?!\\.{1,2}$)[A-Za-z0-9_.-]+$"
    },
    "status": {
      "const": "complete"
    },
    "publication": {
      "$ref": "#/$defs/publication"
    },
    "verification": {
      "$ref": "zcc-pull-artifact-parity.schema.json"
    }
  },
  "allOf": [
    {
      "type": "object",
      "properties": {
        "verification": {
          "type": "object",
          "properties": {
            "status": {
              "const": "ready"
            },
            "candidate": {
              "type": "object",
              "properties": {
                "status": {
                  "const": "ready"
                }
              }
            },
            "parity": {
              "type": "object",
              "properties": {
                "status": {
                  "const": "equal"
                }
              }
            }
          }
        }
      }
    }
  ],
  "$defs": {
    "artifactName": {
      "enum": [
        "imports",
        "lookup",
        "tfvars"
      ]
    },
    "artifactNames": {
      "type": "array",
      "maxItems": 3,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/artifactName"
      }
    },
    "publication": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "policy",
        "created",
        "reused"
      ],
      "properties": {
        "policy": {
          "const": "create_or_verify_exact"
        },
        "created": {
          "$ref": "#/$defs/artifactNames"
        },
        "reused": {
          "$ref": "#/$defs/artifactNames"
        }
      }
    }
  }
}
