{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://infrawright.local/schemas/transform-resource-cohort.schema.json",
  "title": "Infrawright ZIA Transform Resource Cohort",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "kind",
    "schema_version",
    "product",
    "resources",
    "source_files",
    "sources_sha256"
  ],
  "properties": {
    "kind": {
      "const": "infrawright.transform_resource_cohort"
    },
    "schema_version": {
      "const": 1
    },
    "product": {
      "const": "zia"
    },
    "resources": {
      "type": "array",
      "minItems": 3,
      "maxItems": 3,
      "items": {
        "$ref": "#/$defs/resource"
      },
      "allOf": [
        {
          "contains": {
            "type": "object",
            "properties": {
              "type": {
                "const": "zia_admin_roles"
              }
            },
            "required": [
              "type"
            ]
          }
        },
        {
          "contains": {
            "type": "object",
            "properties": {
              "type": {
                "const": "zia_traffic_forwarding_static_ip"
              }
            },
            "required": [
              "type"
            ]
          }
        },
        {
          "contains": {
            "type": "object",
            "properties": {
              "type": {
                "const": "zia_url_categories"
              }
            },
            "required": [
              "type"
            ]
          }
        }
      ]
    },
    "source_files": {
      "type": "array",
      "minItems": 6,
      "maxItems": 6,
      "uniqueItems": true,
      "items": {
        "enum": [
          "zia/overrides/zia_admin_roles.json",
          "zia/overrides/zia_traffic_forwarding_static_ip.json",
          "zia/overrides/zia_url_categories.json",
          "zia/pack.json",
          "zia/registry.json",
          "zia/schemas/provider/zia.json"
        ]
      }
    },
    "sources_sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    }
  },
  "$defs": {
    "resource": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "key_fields",
        "html_unescape_passes",
        "acknowledged_drops",
        "invert_bool",
        "import_id",
        "lookup_source",
        "renames",
        "references",
        "split_csv",
        "projection"
      ],
      "properties": {
        "type": {
          "$ref": "https://infrawright.local/schemas/transform-catalog.schema.json#/$defs/fieldName"
        },
        "key_fields": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "https://infrawright.local/schemas/transform-catalog.schema.json#/$defs/fieldName"
          }
        },
        "html_unescape_passes": {
          "const": 0
        },
        "acknowledged_drops": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "$ref": "https://infrawright.local/schemas/transform-catalog.schema.json#/$defs/fieldPath"
          }
        },
        "invert_bool": {
          "type": "array",
          "maxItems": 0
        },
        "import_id": {
          "$ref": "https://infrawright.local/schemas/transform-catalog.schema.json#/$defs/importId"
        },
        "lookup_source": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "$ref": "https://infrawright.local/schemas/transform-catalog.schema.json#/$defs/lookupSource"
            }
          ]
        },
        "renames": {
          "type": "object",
          "maxProperties": 0
        },
        "references": {
          "type": "object",
          "maxProperties": 0
        },
        "skip_if": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "minProperties": 1,
            "additionalProperties": {
              "anyOf": [
                {
                  "type": "boolean"
                },
                {
                  "type": "null"
                },
                {
                  "type": "number"
                },
                {
                  "type": "string"
                }
              ]
            }
          }
        },
        "sort_lists": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "$ref": "https://infrawright.local/schemas/transform-catalog.schema.json#/$defs/fieldName"
          }
        },
        "split_csv": {
          "type": "array",
          "maxItems": 0
        },
        "projection": {
          "$ref": "https://infrawright.local/schemas/transform-catalog.schema.json#/$defs/projection"
        }
      }
    }
  }
}
