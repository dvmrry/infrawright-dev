{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://infrawright.local/schemas/source-operation-evidence.schema.json",
  "title": "Source Operation Evidence Registry",
  "description": "Resource-keyed evidence emitted by source-operation-map and future source analyzers.",
  "type": "object",
  "additionalProperties": {
    "$ref": "#/$defs/resourceEvidence"
  },
  "$defs": {
    "resourceEvidence": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "product",
        "surface",
        "status",
        "source"
      ],
      "properties": {
        "product": {
          "type": "string"
        },
        "surface": {
          "type": "string"
        },
        "status": {
          "enum": [
            "mapped",
            "ambiguous_source_operation",
            "unmapped"
          ]
        },
        "read": {
          "$ref": "#/$defs/operationEvidence"
        },
        "list": {
          "$ref": "#/$defs/operationEvidence"
        },
        "write": {
          "$ref": "#/$defs/operationEvidence"
        },
        "action": {
          "$ref": "#/$defs/operationEvidence"
        },
        "source": {
          "type": "object",
          "additionalProperties": true,
          "required": [
            "candidate_count",
            "files"
          ],
          "properties": {
            "candidate_count": {
              "type": "integer",
              "minimum": 0
            },
            "files": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "sdk_path_unresolved": {
              "type": "array",
              "description": "SDK calls whose path template could not be resolved to an OpenAPI operation. Reported per-call so failures are visible rather than silently falling back to fuzzy scoring.",
              "items": {
                "type": "object",
                "additionalProperties": true,
                "required": [
                  "client_symbol",
                  "reason"
                ],
                "properties": {
                  "client_symbol": {
                    "type": "string"
                  },
                  "sdk_file": {
                    "type": [
                      "string",
                      "null"
                    ]
                  },
                  "reason": {
                    "enum": [
                      "sdk_symbol_not_found",
                      "path_template_not_found",
                      "method_not_detected",
                      "openapi_path_not_found",
                      "openapi_path_ambiguous"
                    ]
                  },
                  "ambiguous_openapi_paths": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  }
                }
              }
            },
            "sdk_action_paths": {
              "type": "array",
              "description": "Non-GET SDK paths extracted from SDK source. Surfaced as action evidence so callers can see write/action shapes without confusing them with read paths.",
              "items": {
                "type": "object",
                "additionalProperties": true,
                "required": [
                  "client_symbol",
                  "method",
                  "path_template"
                ],
                "properties": {
                  "client_symbol": {
                    "type": "string"
                  },
                  "method": {
                    "type": "string"
                  },
                  "path_template": {
                    "type": "string"
                  },
                  "sdk_file": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "candidates": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/operationEvidence"
          }
        },
        "reason": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "operationEvidence": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "evidence_kind",
        "confidence",
        "hops"
      ],
      "properties": {
        "evidence_kind": {
          "enum": [
            "fetch",
            "read",
            "list",
            "write",
            "action"
          ]
        },
        "confidence": {
          "enum": [
            "high",
            "medium",
            "low"
          ]
        },
        "operation_id": {
          "type": "string"
        },
        "method": {
          "type": "string"
        },
        "path": {
          "type": "string"
        },
        "path_kind": {
          "enum": [
            "detail",
            "list",
            "action",
            "unknown"
          ]
        },
        "hops": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/evidenceHop"
          }
        }
      }
    },
    "evidenceHop": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "kind"
      ],
      "properties": {
        "kind": {
          "enum": [
            "provider_call",
            "sdk_operation",
            "sdk_path",
            "openapi_operation",
            "manual_inference"
          ]
        },
        "client_package": {
          "type": "string"
        },
        "client_symbol": {
          "type": "string"
        },
        "operation_id": {
          "type": "string"
        },
        "method": {
          "type": "string"
        },
        "path": {
          "type": "string"
        },
        "path_template": {
          "type": "string",
          "description": "Path template recovered from SDK source, e.g. v2/domains/{domain}."
        },
        "sdk_file": {
          "type": "string",
          "description": "SDK source file (relative to sdk-root) the path template was extracted from."
        },
        "ambiguous_openapi_paths": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "source_files": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "matched_aliases": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}
