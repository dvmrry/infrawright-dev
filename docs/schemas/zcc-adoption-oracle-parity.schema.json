{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://infrawright.local/schemas/zcc-adoption-oracle-parity.schema.json",
  "title": "Infrawright ZCC Adoption Oracle Parity",
  "$comment": "This report is a closed, secret-safe comparison contract produced and consumed only inside one trusted process or an authenticated CI artifact channel. Tenant-derived identities, provider observations, projections, and artifact bytes appear only as domain-separated HMAC-SHA256 commitments made with a fresh process-held 32-byte key. Public catalog/build bindings and the digest of this already-redacted report use plain SHA-256. The semantic validator and report digest detect structural or accidental corruption; they do not authenticate the evidence or its producer, and this contract defines no signing or key-distribution system. Semantic validation derives comparison statuses, counts, reference stability, exact five-resource scope, and trusted-network-only lookup applicability. It validates the claimed aggregate live-input coverage enum but cannot independently derive that redacted coverage bit. Aggregate coverage discloses one bit for the complete five-resource run and never per-resource presence. Version 1 is comparison-only: both qualification fields are always not_qualified because evidence class and build bindings remain caller assertions at this private seam. A host-bound successor schema is required before any projection, executor, or cutover qualification claim. A future public operation must derive the evidence class and public build hashes from its own execution and generate a fresh random 32-byte commitment key internally.",
  "type": "object",
  "x-infrawright-zcc-adoption-oracle-parity-semantics": true,
  "additionalProperties": false,
  "required": [
    "kind",
    "schema_version",
    "product",
    "evidence_class",
    "bindings",
    "resources",
    "summary",
    "report_sha256"
  ],
  "properties": {
    "kind": {
      "const": "infrawright.zcc_adoption_oracle_parity"
    },
    "schema_version": {
      "const": 1
    },
    "product": {
      "const": "zcc"
    },
    "evidence_class": {
      "enum": [
        "simulation",
        "live_shared_observation",
        "live_independent_executor"
      ]
    },
    "bindings": {
      "$ref": "#/$defs/bindings"
    },
    "resources": {
      "type": "array",
      "minItems": 5,
      "maxItems": 5,
      "prefixItems": [
        {
          "allOf": [
            { "$ref": "#/$defs/resource" },
            {
              "type": "object",
              "properties": {
                "resource_type": { "const": "zcc_device_cleanup" }
              }
            }
          ]
        },
        {
          "allOf": [
            { "$ref": "#/$defs/resource" },
            {
              "type": "object",
              "properties": {
                "resource_type": { "const": "zcc_failopen_policy" }
              }
            }
          ]
        },
        {
          "allOf": [
            { "$ref": "#/$defs/resource" },
            {
              "type": "object",
              "properties": {
                "resource_type": { "const": "zcc_forwarding_profile" }
              }
            }
          ]
        },
        {
          "allOf": [
            { "$ref": "#/$defs/resource" },
            {
              "type": "object",
              "properties": {
                "resource_type": { "const": "zcc_trusted_network" }
              }
            }
          ]
        },
        {
          "allOf": [
            { "$ref": "#/$defs/resource" },
            {
              "type": "object",
              "properties": {
                "resource_type": { "const": "zcc_web_privacy" }
              }
            }
          ]
        }
      ],
      "items": false
    },
    "summary": {
      "$ref": "#/$defs/summary"
    },
    "report_sha256": {
      "$ref": "#/$defs/sha256"
    }
  },
  "allOf": [
    {
      "if": {
        "type": "object",
        "properties": {
          "evidence_class": { "const": "simulation" }
        }
      },
      "then": {
        "type": "object",
        "properties": {
          "bindings": {
            "type": "object",
            "properties": {
              "builds": { "$ref": "#/$defs/buildsWithoutAfter" }
            }
          },
          "summary": {
            "type": "object",
            "properties": {
              "projection_qualification": { "const": "not_qualified" },
              "executor_qualification": { "const": "not_qualified" },
              "live_input_coverage": { "const": "not_applicable" }
            }
          }
        }
      }
    },
    {
      "if": {
        "type": "object",
        "properties": {
          "evidence_class": { "const": "live_shared_observation" }
        }
      },
      "then": {
        "type": "object",
        "properties": {
          "bindings": {
            "type": "object",
            "properties": {
              "builds": { "$ref": "#/$defs/buildsWithoutAfter" }
            }
          },
          "summary": {
            "type": "object",
            "properties": {
              "live_input_coverage": {
                "enum": ["complete", "incomplete"]
              },
              "executor_qualification": { "const": "not_qualified" }
            }
          }
        }
      }
    },
    {
      "if": {
        "type": "object",
        "properties": {
          "evidence_class": { "const": "live_independent_executor" }
        }
      },
      "then": {
        "type": "object",
        "properties": {
          "bindings": {
            "type": "object",
            "properties": {
              "builds": { "$ref": "#/$defs/buildsWithAfter" }
            }
          },
          "summary": {
            "type": "object",
            "properties": {
              "live_input_coverage": {
                "enum": ["complete", "incomplete"]
              }
            }
          }
        }
      }
    }
  ],
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "hmacSha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "catalog": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "schema_version",
        "sha256",
        "sources_sha256"
      ],
      "properties": {
        "kind": { "const": "infrawright.adoption_catalog" },
        "schema_version": { "const": 1 },
        "sha256": {
          "const": "ba1690397bbe84e6284affee2cfe8300f0ebb230714c332d6ff93d04a42181e7"
        },
        "sources_sha256": {
          "const": "90452e9199dcc4dbf578e9f3af21ae2fb35517eb5d3af0f1a193f2e5ed92ed11"
        }
      }
    },
    "builds": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "python_before_sha256",
        "python_after_sha256",
        "node_sha256",
        "python_stability"
      ],
      "properties": {
        "python_before_sha256": { "$ref": "#/$defs/sha256" },
        "python_after_sha256": {
          "oneOf": [
            { "$ref": "#/$defs/sha256" },
            { "type": "null" }
          ]
        },
        "node_sha256": { "$ref": "#/$defs/sha256" },
        "python_stability": {
          "enum": ["not_applicable", "stable", "unstable"]
        }
      }
    },
    "buildsWithoutAfter": {
      "allOf": [
        { "$ref": "#/$defs/builds" },
        {
          "type": "object",
          "properties": {
            "python_after_sha256": { "type": "null" },
            "python_stability": { "const": "not_applicable" }
          }
        }
      ]
    },
    "buildsWithAfter": {
      "allOf": [
        { "$ref": "#/$defs/builds" },
        {
          "type": "object",
          "properties": {
            "python_after_sha256": { "$ref": "#/$defs/sha256" },
            "python_stability": { "enum": ["stable", "unstable"] }
          }
        }
      ]
    },
    "bindings": {
      "type": "object",
      "additionalProperties": false,
      "required": ["catalog", "builds"],
      "properties": {
        "catalog": { "$ref": "#/$defs/catalog" },
        "builds": { "$ref": "#/$defs/builds" }
      }
    },
    "applicableComparison": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "python_before_hmac_sha256",
        "node_hmac_sha256",
        "python_after_hmac_sha256",
        "status"
      ],
      "properties": {
        "python_before_hmac_sha256": { "$ref": "#/$defs/hmacSha256" },
        "node_hmac_sha256": { "$ref": "#/$defs/hmacSha256" },
        "python_after_hmac_sha256": {
          "oneOf": [
            { "$ref": "#/$defs/hmacSha256" },
            { "type": "null" }
          ]
        },
        "status": {
          "enum": ["match", "mismatch", "unstable_reference"]
        }
      }
    },
    "notApplicableComparison": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "python_before_hmac_sha256",
        "node_hmac_sha256",
        "python_after_hmac_sha256",
        "status"
      ],
      "properties": {
        "python_before_hmac_sha256": { "type": "null" },
        "node_hmac_sha256": { "type": "null" },
        "python_after_hmac_sha256": { "type": "null" },
        "status": { "const": "not_applicable" }
      }
    },
    "comparisons": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "identity",
        "observation",
        "projection",
        "tfvars",
        "imports",
        "lookup"
      ],
      "properties": {
        "identity": { "$ref": "#/$defs/applicableComparison" },
        "observation": { "$ref": "#/$defs/applicableComparison" },
        "projection": { "$ref": "#/$defs/applicableComparison" },
        "tfvars": { "$ref": "#/$defs/applicableComparison" },
        "imports": { "$ref": "#/$defs/applicableComparison" },
        "lookup": {
          "oneOf": [
            { "$ref": "#/$defs/applicableComparison" },
            { "$ref": "#/$defs/notApplicableComparison" }
          ]
        }
      }
    },
    "resource": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "resource_type",
        "status",
        "comparisons"
      ],
      "properties": {
        "resource_type": {
          "enum": [
            "zcc_device_cleanup",
            "zcc_failopen_policy",
            "zcc_forwarding_profile",
            "zcc_trusted_network",
            "zcc_web_privacy"
          ]
        },
        "status": {
          "enum": ["equal", "different", "unstable_reference"]
        },
        "comparisons": { "$ref": "#/$defs/comparisons" }
      },
      "allOf": [
        {
          "if": {
            "type": "object",
            "properties": {
              "resource_type": { "const": "zcc_trusted_network" }
            }
          },
          "then": {
            "type": "object",
            "properties": {
              "comparisons": {
                "type": "object",
                "properties": {
                  "lookup": { "$ref": "#/$defs/applicableComparison" }
                }
              }
            }
          },
          "else": {
            "type": "object",
            "properties": {
              "comparisons": {
                "type": "object",
                "properties": {
                  "lookup": { "$ref": "#/$defs/notApplicableComparison" }
                }
              }
            }
          }
        }
      ]
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "live_input_coverage",
        "total_roles",
        "applicable",
        "matched",
        "mismatched",
        "unstable_reference",
        "not_applicable",
        "projection_qualification",
        "executor_qualification"
      ],
      "properties": {
        "status": {
          "enum": ["equal", "different", "unstable_reference"]
        },
        "live_input_coverage": {
          "enum": ["not_applicable", "complete", "incomplete"]
        },
        "total_roles": { "const": 30 },
        "applicable": { "const": 26 },
        "matched": {
          "type": "integer",
          "minimum": 0,
          "maximum": 26
        },
        "mismatched": {
          "type": "integer",
          "minimum": 0,
          "maximum": 26
        },
        "unstable_reference": {
          "type": "integer",
          "minimum": 0,
          "maximum": 26
        },
        "not_applicable": { "const": 4 },
        "projection_qualification": {
          "const": "not_qualified"
        },
        "executor_qualification": {
          "const": "not_qualified"
        }
      }
    }
  }
}
