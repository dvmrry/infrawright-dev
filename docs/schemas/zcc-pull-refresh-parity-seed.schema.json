{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://infrawright.local/schemas/zcc-pull-refresh-parity-seed.schema.json",
  "title": "Infrawright ZCC Refresh Parity Seed",
  "$comment": "x-infrawright-zcc-pull-refresh-parity-seed-semantics is required. The seed is digest/state evidence only; it contains no artifact contents, provider import IDs, move keys, or physical paths.",
  "type": "object",
  "x-infrawright-zcc-pull-refresh-parity-seed-semantics": true,
  "additionalProperties": false,
  "required": [
    "kind", "schema_version", "mode", "reference", "product",
    "resource_type", "tenant", "bindings", "candidate", "reference_twin",
    "differences", "status", "seed_sha256"
  ],
  "properties": {
    "kind": { "const": "infrawright.zcc_pull_refresh_parity_seed" },
    "schema_version": { "const": 1 },
    "mode": { "const": "refresh" },
    "reference": { "const": "materialized_twin" },
    "product": { "const": "zcc" },
    "resource_type": { "$ref": "zcc-pull-artifact-set.schema.json#/$defs/resourceType" },
    "tenant": {
      "type": "string",
      "pattern": "^(?!\\.{1,2}$)[A-Za-z0-9_.-]+$"
    },
    "bindings": {
      "type": "object",
      "additionalProperties": false,
      "required": ["candidate", "reference_twin"],
      "properties": {
        "candidate": { "$ref": "#/$defs/binding" },
        "reference_twin": { "$ref": "#/$defs/binding" }
      }
    },
    "candidate": { "$ref": "#/$defs/candidateEvidence" },
    "reference_twin": { "$ref": "#/$defs/neutralEvidence" },
    "differences": {
      "type": "array",
      "maxItems": 32,
      "uniqueItems": true,
      "items": {
        "enum": [
          "source", "catalog", "root", "status", "unexpected_drops",
          "baseline.tfvars", "baseline.imports", "baseline.lookup",
          "baseline.moves", "baseline.pending_moves", "baseline.alternate_hcl",
          "baseline.generated_bindings", "desired.tfvars", "desired.imports",
          "desired.lookup", "desired.moves", "desired.pending_moves",
          "desired.alternate_hcl", "desired.generated_bindings",
          "moves.safe_count", "moves.suppressed_count", "decision_sha256",
          "controls.deployment", "controls.root_catalog"
        ]
      }
    },
    "status": { "enum": ["ready", "review_required"] },
    "seed_sha256": { "$ref": "#/$defs/sha256" }
  },
  "$defs": {
    "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "absent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["state"],
      "properties": { "state": { "const": "absent" } }
    },
    "present": {
      "type": "object",
      "additionalProperties": false,
      "required": ["state", "sha256", "size_bytes"],
      "properties": {
        "state": { "const": "present" },
        "sha256": { "$ref": "#/$defs/sha256" },
        "size_bytes": { "type": "integer", "minimum": 0, "maximum": 33554432 }
      }
    },
    "state": {
      "oneOf": [
        { "$ref": "#/$defs/absent" },
        { "$ref": "#/$defs/present" }
      ]
    },
    "desiredPresent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["state", "media_type", "encoding", "sha256", "size_bytes"],
      "properties": {
        "state": { "const": "present" },
        "media_type": { "enum": ["application/json", "text/x-hcl"] },
        "encoding": { "const": "utf-8" },
        "sha256": { "$ref": "#/$defs/sha256" },
        "size_bytes": { "type": "integer", "minimum": 0, "maximum": 33554432 }
      }
    },
    "desiredState": {
      "oneOf": [
        { "$ref": "#/$defs/absent" },
        { "$ref": "#/$defs/desiredPresent" }
      ]
    },
    "states": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "tfvars", "imports", "lookup", "moves", "pending_moves",
        "alternate_hcl", "generated_bindings"
      ],
      "properties": {
        "tfvars": { "$ref": "#/$defs/state" },
        "imports": { "$ref": "#/$defs/state" },
        "lookup": { "$ref": "#/$defs/state" },
        "moves": { "$ref": "#/$defs/state" },
        "pending_moves": { "$ref": "#/$defs/state" },
        "alternate_hcl": { "$ref": "#/$defs/state" },
        "generated_bindings": { "$ref": "#/$defs/state" }
      }
    },
    "desiredStates": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "tfvars", "imports", "lookup", "moves", "pending_moves",
        "alternate_hcl", "generated_bindings"
      ],
      "properties": {
        "tfvars": { "$ref": "#/$defs/desiredState" },
        "imports": { "$ref": "#/$defs/desiredState" },
        "lookup": { "$ref": "#/$defs/desiredState" },
        "moves": { "$ref": "#/$defs/desiredState" },
        "pending_moves": { "$ref": "#/$defs/absent" },
        "alternate_hcl": { "$ref": "#/$defs/absent" },
        "generated_bindings": { "$ref": "#/$defs/absent" }
      }
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sha256", "size_bytes"],
      "properties": {
        "sha256": { "$ref": "#/$defs/sha256" },
        "size_bytes": { "type": "integer", "minimum": 0, "maximum": 4194304 }
      }
    },
    "moves": {
      "type": "object",
      "additionalProperties": false,
      "required": ["safe_count", "suppressed_count"],
      "properties": {
        "safe_count": { "type": "integer", "minimum": 0, "maximum": 50000 },
        "suppressed_count": { "type": "integer", "minimum": 0, "maximum": 50000 }
      }
    },
    "neutralEvidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source", "catalog", "root", "baseline", "desired", "status",
        "unexpected_drops", "moves", "decision_sha256", "evidence_sha256"
      ],
      "properties": {
        "source": { "$ref": "#/$defs/source" },
        "catalog": { "$ref": "zcc-pull-artifact-set.schema.json#/$defs/catalog" },
        "root": { "$ref": "zcc-pull-artifact-set.schema.json#/$defs/root" },
        "baseline": { "$ref": "#/$defs/states" },
        "desired": { "$ref": "#/$defs/desiredStates" },
        "status": { "enum": ["ready", "review_required"] },
        "unexpected_drops": {
          "type": "array",
          "maxItems": 50000,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        },
        "moves": { "$ref": "#/$defs/moves" },
        "decision_sha256": { "$ref": "#/$defs/sha256" },
        "evidence_sha256": { "$ref": "#/$defs/sha256" }
      }
    },
    "candidateEvidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source", "catalog", "root", "baseline", "desired", "status",
        "unexpected_drops", "moves", "decision_sha256", "evidence_sha256",
        "baseline_fingerprint_sha256", "transition_sha256"
      ],
      "properties": {
        "source": { "$ref": "#/$defs/source" },
        "catalog": { "$ref": "zcc-pull-artifact-set.schema.json#/$defs/catalog" },
        "root": { "$ref": "zcc-pull-artifact-set.schema.json#/$defs/root" },
        "baseline": { "$ref": "#/$defs/states" },
        "desired": { "$ref": "#/$defs/desiredStates" },
        "status": { "enum": ["ready", "review_required"] },
        "unexpected_drops": {
          "type": "array",
          "maxItems": 50000,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        },
        "moves": { "$ref": "#/$defs/moves" },
        "decision_sha256": { "$ref": "#/$defs/sha256" },
        "evidence_sha256": { "$ref": "#/$defs/sha256" },
        "baseline_fingerprint_sha256": { "$ref": "#/$defs/sha256" },
        "transition_sha256": { "$ref": "#/$defs/sha256" }
      }
    },
    "binding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "request_sha256", "binding_sha256", "deployment_semantics_sha256", "controls"
      ],
      "properties": {
        "request_sha256": { "$ref": "#/$defs/sha256" },
        "binding_sha256": { "$ref": "#/$defs/sha256" },
        "deployment_semantics_sha256": { "$ref": "#/$defs/sha256" },
        "controls": {
          "type": "object",
          "additionalProperties": false,
          "required": ["deployment", "root_catalog"],
          "properties": {
            "deployment": { "$ref": "#/$defs/state" },
            "root_catalog": { "$ref": "#/$defs/present" }
          }
        }
      }
    }
  }
}
