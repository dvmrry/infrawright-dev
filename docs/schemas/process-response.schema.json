{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://infrawright.local/schemas/process-response.schema.json",
  "title": "Infrawright Process Response",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "kind",
    "schema_version",
    "request_id",
    "operation",
    "status",
    "diagnostics",
    "result",
    "error"
  ],
  "properties": {
    "kind": {
      "const": "infrawright.process_response"
    },
    "schema_version": {
      "const": 1
    },
    "request_id": {
      "type": [
        "string",
        "null"
      ],
      "maxLength": 256
    },
    "operation": {
      "oneOf": [
        {
          "const": "roots"
        },
        {
          "const": "scope_paths"
        },
        {
          "const": "plan_roots"
        },
        {
          "const": "assess_saved_plans"
        },
        {
          "const": "compile_pull_artifacts"
        },
        {
          "const": "seed_pull_refresh_parity"
        },
        {
          "const": "compare_pull_artifacts"
        },
        {
          "const": "materialize_pull_artifacts"
        },
        {
          "type": "null"
        }
      ]
    },
    "status": {
      "enum": [
        "ok",
        "error"
      ]
    },
    "diagnostics": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/diagnostic"
      }
    },
    "result": {
      "oneOf": [
        {
          "$ref": "root-topology.schema.json"
        },
        {
          "$ref": "changed-path-scope.schema.json"
        },
        {
          "$ref": "plan-roots.schema.json"
        },
        {
          "$ref": "saved-plan-assessment.schema.json"
        },
        {
          "$ref": "zcc-pull-artifact-set.schema.json"
        },
        {
          "$ref": "zcc-pull-refresh-artifact-set.schema.json"
        },
        {
          "$ref": "zcc-pull-refresh-parity-seed.schema.json"
        },
        {
          "$ref": "zcc-pull-refresh-parity.schema.json"
        },
        {
          "$ref": "zcc-pull-artifact-parity.schema.json"
        },
        {
          "$ref": "zcc-pull-artifact-materialization.schema.json"
        },
        {
          "$ref": "zcc-pull-refresh-materialization.schema.json"
        },
        {
          "type": "null"
        }
      ]
    },
    "error": {
      "oneOf": [
        {
          "$ref": "#/$defs/error"
        },
        {
          "type": "null"
        }
      ]
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "status": {
            "const": "ok"
          }
        }
      },
      "then": {
        "oneOf": [
          {
            "properties": {
              "request_id": {
                "type": "string"
              },
              "operation": {
                "const": "seed_pull_refresh_parity"
              },
              "diagnostics": {
                "type": "array",
                "maxItems": 0
              },
              "result": {
                "$ref": "zcc-pull-refresh-parity-seed.schema.json"
              },
              "error": {
                "type": "null"
              }
            }
          },
          {
            "properties": {
              "request_id": {
                "type": "string"
              },
              "operation": {
                "const": "roots"
              },
              "result": {
                "$ref": "root-topology.schema.json"
              },
              "error": {
                "type": "null"
              }
            }
          },
          {
            "properties": {
              "request_id": {
                "type": "string"
              },
              "operation": {
                "const": "scope_paths"
              },
              "diagnostics": {
                "type": "array",
                "maxItems": 0
              },
              "result": {
                "$ref": "changed-path-scope.schema.json"
              },
              "error": {
                "type": "null"
              }
            }
          },
          {
            "properties": {
              "request_id": {
                "type": "string"
              },
              "operation": {
                "const": "plan_roots"
              },
              "result": {
                "$ref": "plan-roots.schema.json"
              },
              "error": {
                "type": "null"
              }
            }
          },
          {
            "properties": {
              "request_id": {
                "type": "string"
              },
              "operation": {
                "const": "assess_saved_plans"
              },
              "result": {
                "$ref": "saved-plan-assessment.schema.json"
              },
              "error": {
                "type": "null"
              }
            }
          },
          {
            "properties": {
              "request_id": {
                "type": "string"
              },
              "operation": {
                "const": "compile_pull_artifacts"
              },
              "diagnostics": {
                "type": "array",
                "maxItems": 0
              },
              "result": {
                "oneOf": [
                  {
                    "$ref": "zcc-pull-artifact-set.schema.json"
                  },
                  {
                    "$ref": "zcc-pull-refresh-artifact-set.schema.json"
                  }
                ]
              },
              "error": {
                "type": "null"
              }
            }
          },
          {
            "properties": {
              "request_id": {
                "type": "string"
              },
              "operation": {
                "const": "compare_pull_artifacts"
              },
              "diagnostics": {
                "type": "array",
                "maxItems": 0
              },
              "result": {
                "oneOf": [
                  { "$ref": "zcc-pull-artifact-parity.schema.json" },
                  { "$ref": "zcc-pull-refresh-parity.schema.json" }
                ]
              },
              "error": {
                "type": "null"
              }
            }
          },
          {
            "properties": {
              "request_id": {
                "type": "string"
              },
              "operation": {
                "const": "materialize_pull_artifacts"
              },
              "diagnostics": {
                "type": "array",
                "maxItems": 0
              },
              "result": {
                "oneOf": [
                  {
                    "$ref": "zcc-pull-artifact-materialization.schema.json"
                  },
                  {
                    "$ref": "zcc-pull-refresh-materialization.schema.json"
                  }
                ]
              },
              "error": {
                "type": "null"
              }
            }
          }
        ]
      },
      "else": {
        "properties": {
          "diagnostics": {
            "type": "array",
            "maxItems": 0
          },
          "result": {
            "type": "null"
          },
          "error": {
            "$ref": "#/$defs/error"
          }
        }
      }
    }
  ],
  "$defs": {
    "diagnostic": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "level",
        "code",
        "message",
        "selected_members",
        "root",
        "additional_members"
      ],
      "properties": {
        "level": {
          "const": "note"
        },
        "code": {
          "const": "WHOLE_ROOT_SELECTION"
        },
        "message": {
          "type": "string"
        },
        "selected_members": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "root": {
          "type": "string"
        },
        "additional_members": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "error": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "code",
        "category",
        "message",
        "retryable",
        "details"
      ],
      "properties": {
        "code": {
          "type": "string",
          "pattern": "^[A-Z][A-Z0-9_]*$"
        },
        "category": {
          "enum": [
            "request",
            "domain",
            "io",
            "internal"
          ]
        },
        "message": {
          "type": "string"
        },
        "retryable": {
          "type": "boolean"
        },
        "details": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "path",
              "code",
              "message"
            ],
            "properties": {
              "path": {
                "type": "string"
              },
              "code": {
                "type": "string"
              },
              "message": {
                "type": "string"
              }
            }
          }
        }
      }
    }
  }
}
