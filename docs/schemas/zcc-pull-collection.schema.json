{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://infrawright.local/schemas/zcc-pull-collection.schema.json",
  "title": "ZCC Pull Collection Receipt",
  "$comment": "Structural validation is insufficient: consumers must also run the custom x-infrawright-zcc-pull-collection-semantics checks.",
  "type": "object",
  "x-infrawright-zcc-pull-collection-semantics": true,
  "additionalProperties": false,
  "required": [
    "kind",
    "schema_version",
    "mode",
    "product",
    "tenant",
    "resource_type",
    "status",
    "catalog_sources_sha256",
    "artifact",
    "publication"
  ],
  "properties": {
    "kind": { "const": "infrawright.zcc_pull_collection" },
    "schema_version": { "const": 1 },
    "mode": { "const": "oneapi" },
    "product": { "const": "zcc" },
    "tenant": {
      "type": "string",
      "maxLength": 255,
      "pattern": "^(?!\\.{1,2}$)[A-Za-z0-9_.-]+$"
    },
    "resource_type": { "$ref": "zcc-pull-artifact-set.schema.json#/$defs/resourceType" },
    "status": { "const": "complete" },
    "catalog_sources_sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path", "media_type", "encoding", "sha256", "size_bytes", "item_count"
      ],
      "properties": {
        "path": { "type": "string", "pattern": "^pulls/[^/]+/zcc_[a-z_]+\\.json$" },
        "media_type": { "const": "application/json" },
        "encoding": { "const": "utf-8" },
        "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
        "size_bytes": { "type": "integer", "minimum": 0, "maximum": 4194304 },
        "item_count": { "type": "integer", "minimum": 0, "maximum": 50000 }
      }
    },
    "publication": {
      "type": "object",
      "additionalProperties": false,
      "required": ["policy", "action"],
      "properties": {
        "policy": { "const": "replace_or_verify_exact" },
        "action": { "enum": ["created", "replaced", "reused"] }
      }
    }
  }
}
