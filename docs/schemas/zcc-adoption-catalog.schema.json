{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://infrawright.local/schemas/zcc-adoption-catalog.schema.json",
  "title": "Infrawright ZCC Adoption Catalog",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "kind",
    "schema_version",
    "product",
    "provider",
    "resources",
    "source_files",
    "sources_sha256"
  ],
  "properties": {
    "kind": {
      "const": "infrawright.adoption_catalog"
    },
    "schema_version": {
      "const": 1
    },
    "product": {
      "const": "zcc"
    },
    "provider": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "source",
        "version"
      ],
      "properties": {
        "name": {
          "const": "zcc"
        },
        "source": {
          "const": "zscaler/zcc"
        },
        "version": {
          "const": "0.1.0-beta.1"
        }
      }
    },
    "resources": {
      "type": "array",
      "minItems": 5,
      "maxItems": 5,
      "items": {
        "$ref": "#/$defs/resource"
      },
      "allOf": [
        {
          "contains": {
            "type": "object",
            "properties": {
              "type": {
                "const": "zcc_device_cleanup"
              }
            },
            "required": [
              "type"
            ]
          }
        },
        {
          "contains": {
            "type": "object",
            "properties": {
              "type": {
                "const": "zcc_failopen_policy"
              }
            },
            "required": [
              "type"
            ]
          }
        },
        {
          "contains": {
            "type": "object",
            "properties": {
              "type": {
                "const": "zcc_forwarding_profile"
              }
            },
            "required": [
              "type"
            ]
          }
        },
        {
          "contains": {
            "type": "object",
            "properties": {
              "type": {
                "const": "zcc_trusted_network"
              }
            },
            "required": [
              "type"
            ]
          }
        },
        {
          "contains": {
            "type": "object",
            "properties": {
              "type": {
                "const": "zcc_web_privacy"
              }
            },
            "required": [
              "type"
            ]
          }
        }
      ]
    },
    "source_files": {
      "type": "array",
      "minItems": 8,
      "maxItems": 8,
      "uniqueItems": true,
      "items": {
        "enum": [
          "zcc/overrides/zcc_device_cleanup.json",
          "zcc/overrides/zcc_failopen_policy.json",
          "zcc/overrides/zcc_forwarding_profile.json",
          "zcc/overrides/zcc_trusted_network.json",
          "zcc/overrides/zcc_web_privacy.json",
          "zcc/pack.json",
          "zcc/registry.json",
          "zcc/schemas/provider/zcc.json"
        ]
      }
    },
    "sources_sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    }
  },
  "$defs": {
    "fieldName": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*$"
    },
    "fieldPath": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*(?:\\.[a-z][a-z0-9_]*)*$"
    },
    "primitiveEncoding": {
      "enum": [
        "bool",
        "number",
        "string"
      ]
    },
    "encoding": {
      "oneOf": [
        {
          "$ref": "#/$defs/primitiveEncoding"
        },
        {
          "type": "array",
          "minItems": 2,
          "maxItems": 2,
          "prefixItems": [
            {
              "const": "list"
            },
            {
              "$ref": "#/$defs/primitiveEncoding"
            }
          ],
          "items": false
        }
      ]
    },
    "attributeProjection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "encoding",
        "provider_sensitive",
        "status"
      ],
      "properties": {
        "encoding": {
          "$ref": "#/$defs/encoding"
        },
        "provider_sensitive": {
          "type": "boolean"
        },
        "status": {
          "enum": [
            "required",
            "optional"
          ]
        }
      }
    },
    "projection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "attributes",
        "blocks",
        "computed_only_attributes",
        "computed_only_blocks"
      ],
      "properties": {
        "attributes": {
          "type": "object",
          "propertyNames": {
            "$ref": "#/$defs/fieldName"
          },
          "additionalProperties": {
            "$ref": "#/$defs/attributeProjection"
          }
        },
        "blocks": {
          "type": "object",
          "propertyNames": {
            "$ref": "#/$defs/fieldName"
          },
          "additionalProperties": {
            "$ref": "#/$defs/blockProjection"
          }
        },
        "computed_only_attributes": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/fieldName"
          }
        },
        "computed_only_blocks": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/fieldName"
          }
        }
      }
    },
    "blockProjection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "cardinality",
        "nesting_mode",
        "projection",
        "status"
      ],
      "properties": {
        "cardinality": {
          "enum": [
            "single",
            "many"
          ]
        },
        "nesting_mode": {
          "enum": [
            "single",
            "list",
            "set"
          ]
        },
        "projection": {
          "$ref": "#/$defs/projection"
        },
        "status": {
          "enum": [
            "required",
            "optional"
          ]
        }
      }
    },
    "scalar": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "type": "boolean"
        },
        {
          "type": "number"
        },
        {
          "type": "string"
        }
      ]
    },
    "skipMatcher": {
      "type": "object",
      "minProperties": 1,
      "propertyNames": {
        "$ref": "#/$defs/fieldName"
      },
      "additionalProperties": {
        "$ref": "#/$defs/scalar"
      }
    },
    "numericSkipMatcher": {
      "type": "object",
      "minProperties": 1,
      "propertyNames": {
        "$ref": "#/$defs/fieldName"
      },
      "additionalProperties": {
        "type": "number"
      }
    },
    "importSegment": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "literal"
          ],
          "properties": {
            "literal": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "field"
          ],
          "properties": {
            "field": {
              "$ref": "#/$defs/fieldName"
            }
          }
        }
      ]
    },
    "importId": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "segments",
        "template"
      ],
      "properties": {
        "segments": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/importSegment"
          }
        },
        "template": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "identity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "constant_key",
        "identity_fields",
        "identity_renames",
        "import_id",
        "key_fields",
        "skip_if",
        "skip_if_lte"
      ],
      "properties": {
        "constant_key": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "type": "string",
              "minLength": 1
            }
          ]
        },
        "identity_fields": {
          "type": "object",
          "propertyNames": {
            "$ref": "#/$defs/fieldName"
          },
          "additionalProperties": {
            "$ref": "#/$defs/fieldPath"
          }
        },
        "identity_renames": {
          "type": "object",
          "propertyNames": {
            "$ref": "#/$defs/fieldName"
          },
          "additionalProperties": {
            "$ref": "#/$defs/fieldName"
          }
        },
        "import_id": {
          "$ref": "#/$defs/importId"
        },
        "key_fields": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/fieldPath"
          }
        },
        "skip_if": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/skipMatcher"
          }
        },
        "skip_if_lte": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/numericSkipMatcher"
          }
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "constant_key": {
                "type": "null"
              }
            },
            "required": [
              "constant_key"
            ]
          },
          "then": {
            "properties": {
              "key_fields": {
                "type": "array",
                "minItems": 1
              }
            }
          },
          "else": {
            "properties": {
              "key_fields": {
                "type": "array",
                "maxItems": 0
              }
            }
          }
        }
      ]
    },
    "resource": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "identity",
        "lookup_source",
        "projection"
      ],
      "properties": {
        "type": {
          "enum": [
            "zcc_device_cleanup",
            "zcc_failopen_policy",
            "zcc_forwarding_profile",
            "zcc_trusted_network",
            "zcc_web_privacy"
          ]
        },
        "identity": {
          "$ref": "#/$defs/identity"
        },
        "lookup_source": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "name_field"
              ],
              "properties": {
                "name_field": {
                  "$ref": "#/$defs/fieldName"
                }
              }
            }
          ]
        },
        "projection": {
          "$ref": "#/$defs/projection"
        }
      }
    }
  }
}
