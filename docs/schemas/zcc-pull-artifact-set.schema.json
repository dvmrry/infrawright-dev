{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://infrawright.local/schemas/zcc-pull-artifact-set.schema.json",
  "title": "Infrawright ZCC Bootstrap Pull Artifact Set",
  "type": "object",
  "x-infrawright-zcc-pull-artifact-semantics": true,
  "additionalProperties": false,
  "required": [
    "kind",
    "schema_version",
    "mode",
    "product",
    "resource_type",
    "tenant",
    "source",
    "catalog",
    "root",
    "status",
    "unexpected_drops",
    "artifacts"
  ],
  "properties": {
    "kind": {
      "const": "infrawright.zcc_pull_artifact_set"
    },
    "schema_version": {
      "const": 1
    },
    "mode": {
      "const": "bootstrap"
    },
    "product": {
      "const": "zcc"
    },
    "resource_type": {
      "$ref": "#/$defs/resourceType"
    },
    "tenant": {
      "type": "string",
      "pattern": "^(?!\\.{1,2}$)[A-Za-z0-9_.-]+$"
    },
    "source": {
      "$ref": "#/$defs/source"
    },
    "catalog": {
      "$ref": "#/$defs/catalog"
    },
    "root": {
      "$ref": "#/$defs/root"
    },
    "status": {
      "enum": [
        "ready",
        "review_required"
      ]
    },
    "unexpected_drops": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "artifacts": {
      "$ref": "#/$defs/artifacts"
    }
  },
  "allOf": [
    {
      "if": {
        "type": "object",
        "properties": {
          "unexpected_drops": {
            "type": "array",
            "maxItems": 0
          }
        }
      },
      "then": {
        "type": "object",
        "properties": {
          "status": {
            "const": "ready"
          }
        }
      },
      "else": {
        "type": "object",
        "properties": {
          "status": {
            "const": "review_required"
          }
        }
      }
    },
    {
      "if": {
        "type": "object",
        "properties": {
          "resource_type": {
            "const": "zcc_trusted_network"
          }
        }
      },
      "then": {
        "type": "object",
        "properties": {
          "artifacts": {
            "type": "object",
            "properties": {
              "lookup": {
                "$ref": "#/$defs/jsonArtifact"
              }
            }
          }
        }
      },
      "else": {
        "type": "object",
        "properties": {
          "artifacts": {
            "type": "object",
            "properties": {
              "lookup": {
                "type": "null"
              }
            }
          }
        }
      }
    }
  ],
  "$defs": {
    "resourceType": {
      "enum": [
        "zcc_device_cleanup",
        "zcc_failopen_policy",
        "zcc_forwarding_profile",
        "zcc_trusted_network",
        "zcc_web_privacy"
      ]
    },
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "sha256",
        "size_bytes"
      ],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1
        },
        "sha256": {
          "$ref": "#/$defs/sha256"
        },
        "size_bytes": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        }
      }
    },
    "catalog": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "schema_version",
        "sha256",
        "sources_sha256"
      ],
      "properties": {
        "kind": {
          "const": "infrawright.transform_catalog"
        },
        "schema_version": {
          "const": 1
        },
        "sha256": {
          "const": "3900a4d12cd49af7bc8d80248b9c184fa8047ca1987654965a81de87c600937a"
        },
        "sources_sha256": {
          "const": "90452e9199dcc4dbf578e9f3af21ae2fb35517eb5d3af0f1a193f2e5ed92ed11"
        }
      }
    },
    "root": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "label",
        "members",
        "variable_name"
      ],
      "properties": {
        "label": {
          "type": "string",
          "pattern": "^[a-z0-9_]+$"
        },
        "members": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^zcc_[a-z0-9_]+$"
          }
        },
        "variable_name": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*$"
        }
      }
    },
    "textArtifact": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "media_type",
        "encoding",
        "sha256",
        "size_bytes",
        "content"
      ],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1
        },
        "media_type": {
          "enum": [
            "application/json",
            "text/x-hcl"
          ]
        },
        "encoding": {
          "const": "utf-8"
        },
        "sha256": {
          "$ref": "#/$defs/sha256"
        },
        "size_bytes": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        },
        "content": {
          "type": "string"
        }
      }
    },
    "jsonArtifact": {
      "allOf": [
        {
          "$ref": "#/$defs/textArtifact"
        },
        {
          "type": "object",
          "properties": {
            "media_type": {
              "const": "application/json"
            }
          }
        }
      ]
    },
    "hclArtifact": {
      "allOf": [
        {
          "$ref": "#/$defs/textArtifact"
        },
        {
          "type": "object",
          "properties": {
            "media_type": {
              "const": "text/x-hcl"
            }
          }
        }
      ]
    },
    "artifacts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "tfvars",
        "imports",
        "lookup"
      ],
      "properties": {
        "tfvars": {
          "$ref": "#/$defs/jsonArtifact"
        },
        "imports": {
          "$ref": "#/$defs/hclArtifact"
        },
        "lookup": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "$ref": "#/$defs/jsonArtifact"
            }
          ]
        }
      }
    }
  }
}
