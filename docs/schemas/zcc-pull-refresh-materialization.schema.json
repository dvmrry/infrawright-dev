{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://infrawright.local/schemas/zcc-pull-refresh-materialization.schema.json",
  "title": "Infrawright ZCC Pull Refresh Materialization",
  "$comment": "x-infrawright-zcc-pull-refresh-materialization-semantics is required. The report records the imports-last publication state using content-free artifact evidence; it never emits artifact paths, contents, import IDs, or move keys.",
  "type": "object",
  "x-infrawright-zcc-pull-refresh-materialization-semantics": true,
  "additionalProperties": false,
  "required": [
    "kind",
    "schema_version",
    "mode",
    "product",
    "resource_type",
    "tenant",
    "status",
    "publication",
    "transition",
    "verification"
  ],
  "properties": {
    "kind": {
      "const": "infrawright.zcc_pull_refresh_materialization"
    },
    "schema_version": {
      "const": 1
    },
    "mode": {
      "const": "refresh"
    },
    "product": {
      "const": "zcc"
    },
    "resource_type": {
      "$ref": "zcc-pull-artifact-set.schema.json#/$defs/resourceType"
    },
    "tenant": {
      "type": "string",
      "pattern": "^(?!\\.{1,2}$)[A-Za-z0-9_.-]+$"
    },
    "status": {
      "enum": ["complete", "awaiting_apply"]
    },
    "publication": {
      "$ref": "#/$defs/publication"
    },
    "transition": {
      "$ref": "#/$defs/transition"
    },
    "verification": {
      "$ref": "#/$defs/verification"
    }
  },
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "payloadRole": {
      "enum": ["lookup", "moves", "tfvars", "imports"]
    },
    "publication": {
      "type": "object",
      "additionalProperties": false,
      "required": ["policy", "advanced"],
      "properties": {
        "policy": {
          "const": "replace_or_verify_exact_imports_last"
        },
        "advanced": {
          "type": "array",
          "maxItems": 4,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/payloadRole"
          }
        }
      }
    },
    "transition": {
      "type": "object",
      "additionalProperties": false,
      "required": ["initial", "final", "next_action"],
      "properties": {
        "initial": {
          "enum": [
            "precommit",
            "pending_prefix",
            "committed",
            "already_complete"
          ]
        },
        "final": {
          "enum": ["already_complete", "committed"]
        },
        "next_action": {
          "enum": ["none", "apply_moves_then_ack"]
        }
      }
    },
    "absent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["state"],
      "properties": {
        "state": {
          "const": "absent"
        }
      }
    },
    "present": {
      "type": "object",
      "additionalProperties": false,
      "required": ["state", "sha256", "size_bytes"],
      "properties": {
        "state": {
          "const": "present"
        },
        "sha256": {
          "$ref": "#/$defs/sha256"
        },
        "size_bytes": {
          "type": "integer",
          "minimum": 0,
          "maximum": 33554432
        }
      }
    },
    "contentState": {
      "oneOf": [
        {
          "$ref": "#/$defs/absent"
        },
        {
          "$ref": "#/$defs/present"
        }
      ]
    },
    "artifactStates": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "tfvars",
        "imports",
        "lookup",
        "moves",
        "pending_moves",
        "alternate_hcl",
        "generated_bindings"
      ],
      "properties": {
        "tfvars": {
          "$ref": "#/$defs/contentState"
        },
        "imports": {
          "$ref": "#/$defs/contentState"
        },
        "lookup": {
          "$ref": "#/$defs/contentState"
        },
        "moves": {
          "$ref": "#/$defs/contentState"
        },
        "pending_moves": {
          "$ref": "#/$defs/contentState"
        },
        "alternate_hcl": {
          "$ref": "#/$defs/contentState"
        },
        "generated_bindings": {
          "$ref": "#/$defs/contentState"
        }
      }
    },
    "verification": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "candidate_request_sha256",
        "assertion_sha256",
        "baseline_fingerprint_sha256",
        "transition_sha256",
        "artifacts"
      ],
      "properties": {
        "candidate_request_sha256": {
          "$ref": "#/$defs/sha256"
        },
        "assertion_sha256": {
          "$ref": "#/$defs/sha256"
        },
        "baseline_fingerprint_sha256": {
          "$ref": "#/$defs/sha256"
        },
        "transition_sha256": {
          "$ref": "#/$defs/sha256"
        },
        "artifacts": {
          "$ref": "#/$defs/artifactStates"
        }
      }
    }
  }
}
