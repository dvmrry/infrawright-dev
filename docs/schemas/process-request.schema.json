{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://infrawright.local/schemas/process-request.schema.json",
  "title": "Infrawright Process Request",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "kind",
    "schema_version",
    "request_id",
    "operation",
    "context",
    "input"
  ],
  "properties": {
    "kind": {
      "const": "infrawright.process_request"
    },
    "schema_version": {
      "const": 1
    },
    "request_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256
    },
    "operation": {
      "enum": [
        "roots",
        "scope_paths",
        "plan_roots",
        "assess_saved_plans",
        "compile_pull_artifacts"
      ]
    },
    "context": {
      "$ref": "#/$defs/context"
    },
    "input": {
      "oneOf": [
        {
          "$ref": "#/$defs/rootsInput"
        },
        {
          "$ref": "#/$defs/scopePathsInput"
        },
        {
          "$ref": "#/$defs/assessmentInput"
        },
        {
          "$ref": "#/$defs/compilePullArtifactsInput"
        }
      ]
    }
  },
  "oneOf": [
    {
      "properties": {
        "operation": {
          "const": "roots"
        },
        "input": {
          "$ref": "#/$defs/rootsInput"
        }
      }
    },
    {
      "properties": {
        "operation": {
          "const": "assess_saved_plans"
        },
        "input": {
          "$ref": "#/$defs/assessmentInput"
        }
      }
    },
    {
      "properties": {
        "operation": {
          "const": "scope_paths"
        },
        "input": {
          "$ref": "#/$defs/scopePathsInput"
        }
      }
    },
    {
      "properties": {
        "operation": {
          "const": "plan_roots"
        },
        "input": {
          "$ref": "#/$defs/rootsInput"
        }
      }
    },
    {
      "properties": {
        "operation": {
          "const": "compile_pull_artifacts"
        },
        "input": {
          "$ref": "#/$defs/compilePullArtifactsInput"
        }
      }
    }
  ],
  "$defs": {
    "context": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "workspace",
        "deployment",
        "root_catalog"
      ],
      "properties": {
        "workspace": {
          "type": "string",
          "minLength": 1
        },
        "deployment": {
          "type": "string",
          "minLength": 1
        },
        "root_catalog": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "rootsInput": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "tenant",
        "selectors"
      ],
      "properties": {
        "tenant": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "type": "string",
              "pattern": "^(?!\\.{1,2}$)[A-Za-z0-9_.-]+$"
            }
          ]
        },
        "selectors": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "scopePathsInput": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "paths"
      ],
      "properties": {
        "paths": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "assessmentInput": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mode",
        "tenant",
        "selectors",
        "backend_config",
        "policy"
      ],
      "properties": {
        "mode": {
          "enum": [
            "assert-clean",
            "assert-adoptable"
          ]
        },
        "tenant": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "type": "string",
              "pattern": "^(?!\\.{1,2}$)[A-Za-z0-9_.-]+$"
            }
          ]
        },
        "selectors": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "backend_config": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "policy": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "mode": {
                "const": "assert-clean"
              }
            }
          },
          "then": {
            "properties": {
              "policy": {
                "type": "null"
              }
            }
          }
        }
      ]
    },
    "compilePullArtifactsInput": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mode",
        "tenant",
        "resource_type"
      ],
      "properties": {
        "mode": {
          "const": "bootstrap"
        },
        "tenant": {
          "type": "string",
          "pattern": "^(?!\\.{1,2}$)[A-Za-z0-9_.-]+$"
        },
        "resource_type": {
          "enum": [
            "zcc_device_cleanup",
            "zcc_failopen_policy",
            "zcc_forwarding_profile",
            "zcc_trusted_network",
            "zcc_web_privacy"
          ]
        }
      }
    }
  }
}
