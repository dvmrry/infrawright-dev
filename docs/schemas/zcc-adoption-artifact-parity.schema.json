{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://infrawright.local/schemas/zcc-adoption-artifact-parity.schema.json",
  "title": "Infrawright ZCC Provider-Observed Adoption Artifact Parity",
  "$comment": "A content-free comparison between one fresh provider-observed candidate and stable externally materialized bootstrap reference artifacts. Ready means byte equality only; it does not claim plan, apply, live-tenant, or cutover readiness.",
  "type": "object",
  "x-infrawright-zcc-adoption-parity-semantics": true,
  "additionalProperties": false,
  "required": [
    "kind",
    "schema_version",
    "mode",
    "reference",
    "product",
    "resource_type",
    "tenant",
    "source",
    "catalog",
    "root",
    "status",
    "parity"
  ],
  "properties": {
    "kind": {
      "const": "infrawright.zcc_adoption_artifact_parity"
    },
    "schema_version": {
      "const": 1
    },
    "mode": {
      "const": "bootstrap"
    },
    "reference": {
      "const": "materialized"
    },
    "product": {
      "const": "zcc"
    },
    "resource_type": {
      "$ref": "zcc-pull-artifact-set.schema.json#/$defs/resourceType"
    },
    "tenant": {
      "type": "string",
      "pattern": "^(?!\\.{1,2}$)[A-Za-z0-9_.-]+$"
    },
    "source": {
      "$ref": "zcc-pull-artifact-set.schema.json#/$defs/source"
    },
    "catalog": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "schema_version", "sha256", "sources_sha256"],
      "properties": {
        "kind": {
          "const": "infrawright.adoption_catalog"
        },
        "schema_version": {
          "const": 1
        },
        "sha256": {
          "const": "ba1690397bbe84e6284affee2cfe8300f0ebb230714c332d6ff93d04a42181e7"
        },
        "sources_sha256": {
          "const": "90452e9199dcc4dbf578e9f3af21ae2fb35517eb5d3af0f1a193f2e5ed92ed11"
        }
      }
    },
    "root": {
      "$ref": "zcc-pull-artifact-set.schema.json#/$defs/root"
    },
    "status": {
      "enum": ["ready", "review_required"]
    },
    "parity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "equal", "different", "artifacts"],
      "properties": {
        "status": {
          "enum": ["equal", "different"]
        },
        "equal": {
          "type": "integer",
          "minimum": 0,
          "maximum": 3
        },
        "different": {
          "type": "integer",
          "minimum": 0,
          "maximum": 3
        },
        "artifacts": {
          "type": "object",
          "additionalProperties": false,
          "required": ["tfvars", "imports", "lookup"],
          "properties": {
            "tfvars": {
              "$ref": "#/$defs/applicableArtifact"
            },
            "imports": {
              "$ref": "#/$defs/applicableArtifact"
            },
            "lookup": {
              "oneOf": [
                { "$ref": "#/$defs/applicableArtifact" },
                { "$ref": "#/$defs/notApplicableArtifact" }
              ]
            }
          }
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "resource_type": {
            "const": "zcc_trusted_network"
          }
        }
      },
      "then": {
        "properties": {
          "parity": {
            "type": "object",
            "properties": {
              "artifacts": {
                "type": "object",
                "properties": {
                  "lookup": {
                    "$ref": "#/$defs/applicableArtifact"
                  }
                }
              }
            }
          }
        }
      },
      "else": {
        "properties": {
          "parity": {
            "type": "object",
            "properties": {
              "artifacts": {
                "type": "object",
                "properties": {
                  "lookup": {
                    "$ref": "#/$defs/notApplicableArtifact"
                  }
                }
              }
            }
          }
        }
      }
    }
  ],
  "$defs": {
    "candidateDigest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "sha256", "size_bytes"],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1
        },
        "sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "size_bytes": {
          "type": "integer",
          "minimum": 0,
          "maximum": 33554432
        }
      }
    },
    "referenceDigest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "sha256", "size_bytes"],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1
        },
        "sha256": {
          "oneOf": [
            {
              "type": "string",
              "pattern": "^[0-9a-f]{64}$"
            },
            { "type": "null" }
          ]
        },
        "size_bytes": {
          "oneOf": [
            {
              "type": "integer",
              "minimum": 0,
              "maximum": 33554432
            },
            { "type": "null" }
          ]
        }
      }
    },
    "applicableArtifact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["candidate", "reference", "status"],
      "properties": {
        "candidate": {
          "$ref": "#/$defs/candidateDigest"
        },
        "reference": {
          "$ref": "#/$defs/referenceDigest"
        },
        "status": {
          "enum": ["equal", "different"]
        }
      }
    },
    "notApplicableArtifact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["candidate", "reference", "status"],
      "properties": {
        "candidate": { "type": "null" },
        "reference": { "type": "null" },
        "status": { "const": "not_applicable" }
      }
    }
  }
}
