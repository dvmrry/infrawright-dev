{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://infrawright.local/schemas/zcc-pull-refresh-pending-transition.schema.json",
  "title": "Infrawright ZCC Pull Refresh Pending Transition",
  "$comment": "x-infrawright-zcc-pull-refresh-pending-transition-semantics is required. This durable fence contains only content-free transition evidence; artifact paths, contents, import IDs, and move keys are forbidden.",
  "type": "object",
  "x-infrawright-zcc-pull-refresh-pending-transition-semantics": true,
  "additionalProperties": false,
  "required": [
    "kind",
    "schema_version",
    "mode",
    "product",
    "resource_type",
    "tenant",
    "candidate_request_sha256",
    "assertion_sha256",
    "baseline_fingerprint_sha256",
    "transition_sha256",
    "safe_move_count",
    "desired_move"
  ],
  "properties": {
    "kind": {
      "const": "infrawright.zcc_pull_refresh_pending_transition"
    },
    "schema_version": {
      "const": 1
    },
    "mode": {
      "const": "refresh"
    },
    "product": {
      "const": "zcc"
    },
    "resource_type": {
      "$ref": "zcc-pull-artifact-set.schema.json#/$defs/resourceType"
    },
    "tenant": {
      "type": "string",
      "pattern": "^(?!\\.{1,2}$)[A-Za-z0-9_.-]+$"
    },
    "candidate_request_sha256": {
      "$ref": "#/$defs/sha256"
    },
    "assertion_sha256": {
      "$ref": "#/$defs/sha256"
    },
    "baseline_fingerprint_sha256": {
      "$ref": "#/$defs/sha256"
    },
    "transition_sha256": {
      "$ref": "#/$defs/sha256"
    },
    "safe_move_count": {
      "type": "integer",
      "minimum": 0,
      "maximum": 50000
    },
    "desired_move": {
      "$ref": "#/$defs/contentState"
    }
  },
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "absent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["state"],
      "properties": {
        "state": {
          "const": "absent"
        }
      }
    },
    "present": {
      "type": "object",
      "additionalProperties": false,
      "required": ["state", "sha256", "size_bytes"],
      "properties": {
        "state": {
          "const": "present"
        },
        "sha256": {
          "$ref": "#/$defs/sha256"
        },
        "size_bytes": {
          "type": "integer",
          "minimum": 1,
          "maximum": 33554432
        }
      }
    },
    "contentState": {
      "oneOf": [
        {
          "$ref": "#/$defs/absent"
        },
        {
          "$ref": "#/$defs/present"
        }
      ]
    }
  }
}
